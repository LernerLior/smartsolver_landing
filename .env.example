# ── Cosmos DB ──────────────────────────────
COSMOS_ENDPOINT=https://seu-cosmos.documents.azure.com:443/
COSMOS_KEY=sua-chave-aqui
COSMOS_DATABASE=smartsolver
COSMOS_CONTAINER=complaints

# ── IA ─────────────────────────────────────
GEMINI_API_KEY=sua-chave-gemini
GEMINI_MODEL=gemini-3-flash-preview
OPENROUTER_API_KEY=sua-chave-openrouter
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# ── Auth ───────────────────────────────────
LOGIN_KEY=troque-por-uma-chave-secreta-forte
ACCESS_TOKEN_EXPIRE_MINUTES=60
COSMOS_USERS_DATABASE=smartsolver
COSMOS_USERS_CONTAINER=users
COSMOS_COMMENTS_CONTAINER=comments
COSMOS_COMPLETED_CONTAINER=completed

# ── CORS ───────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── E-mail (formulário de contato) ─────────
# Para Gmail: gere uma "Senha de app" em myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
CONTACT_RECIPIENT=seuemail@gmail.com   # onde receber os formulários do site
